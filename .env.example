# Server Config
PORT=5000
JWT_SECRET=campus_return_jwt_secret_key_2026

# Database Mode (set to true to use real Supabase, or false to fallback to local SQLite)
USE_SUPABASE=false

# Supabase Credentials (Required if USE_SUPABASE=true)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
